FROM nvidia/cuda:12.3.2-cudnn9-devel-ubuntu22.04
 
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Berlin
 
# ---------------------------------------------------------------------------
# 1. System dependencies
#    Added libgomp1      → required by PaddlePaddle GPU runtime (OpenMP)
#    Added libstdc++6    → required by Paddle's bundled native libs
#    Added python3-venv  → good practice; avoids pip --break-system-packages
#    Everything else unchanged from original
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    build-essential cmake git wget curl unzip \
    python3 python3-pip python3-dev python3-venv \
    libopencv-dev \
    tesseract-ocr tesseract-ocr-deu \
    libtesseract-dev \
    qt6-base-dev qt6-tools-dev \
    libgl1 libglib2.0-0 \
    libgomp1 libstdc++6 \
    && rm -rf /var/lib/apt/lists/*
 
# ---------------------------------------------------------------------------
# 2. Python AI stack — PaddlePaddle 3.x (replaces old 2.x paddlepaddle-gpu)
#
#    WHY cu118 wheel on CUDA 12.3?
#    Paddle does not publish a cu123-specific wheel. The cu118 build links
#    against CUDA runtime libs that ship inside the wheel itself (via
#    bundled .so files), so it runs correctly on any CUDA 12.x host driver.
#    This is the officially recommended approach for CUDA 12.x users.
#
#    WHY paddleocr[doc-parser]?
#    The [doc-parser] extra pulls in PP-StructureV3 dependencies (layout
#    analysis, table recognition) needed for distinguishing printed vs
#    handwritten regions — core to this project's region classifier.
#
#    WHY a separate index URL (-i flag)?
#    PaddlePaddle GPU wheels are not on PyPI. They are hosted on Paddle's
#    own package server. The -i flag points pip to that server for the
#    paddlepaddle-gpu install only; all other packages still come from PyPI.
# ---------------------------------------------------------------------------
RUN pip3 install --upgrade pip && \
    pip3 install \
        paddlepaddle-gpu==3.0.0 \
        -i https://www.paddlepaddle.org.cn/packages/stable/cu118/ && \
    pip3 install \
        "paddleocr[doc-parser]" \
        opencv-python-headless \
        numpy pillow
 
# ---------------------------------------------------------------------------
# 3. Workspace
#    /workspace is bind-mounted to $HOME on the host at container run-time
#    (see run_exam_extractor.sh). We set it as WORKDIR so any docker exec
#    session drops straight into the project root.
#
#    NOTE — model caching:
#    PaddleOCR downloads models to ~/.paddleocr/ on first use. Because
#    $HOME on the host is mounted to /workspace, the cache lands on the
#    host filesystem and persists across container restarts and recreation.
#    Run scripts/download_models.py once after first container start to
#    pre-populate the cache while you still have internet access.
# ---------------------------------------------------------------------------
WORKDIR /workspace